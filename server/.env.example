# Environment Variables — Copy to .env and fill in your values

PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/pizzaDelivery?retryWrites=true&w=majority
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Razorpay Test Mode Keys (get from https://dashboard.razorpay.com/app/keys)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Email (Gmail with App Password or Ethereal for testing)
EMAIL_HOST=smtp.ethereal.email
EMAIL_PORT=587
EMAIL_USER=your-ethereal-user@ethereal.email
EMAIL_PASS=your-ethereal-password
ADMIN_EMAIL=admin@pizzadelivery.com

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:5173

# Inventory threshold — items below this trigger email alert
INVENTORY_THRESHOLD=20
